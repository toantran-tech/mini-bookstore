# Backend
DATABASE_URL=jdbc:mysql://localhost:3306/minibookstore?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USERNAME=root
DATABASE_PASSWORD=change-me
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-bytes
FRONTEND_URL=http://localhost:5173
# Set true only for the first migration of an existing non-empty database.
FLYWAY_BASELINE_ON_MIGRATE=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Gmail SMTP
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password

# VNPay sandbox
VNPAY_TMN_CODE=your-terminal-code
VNPAY_HASH_SECRET=your-hash-secret
VNPAY_RETURN_URL=http://localhost:8080/api/orders/vnpay-return
FRONTEND_PAYMENT_RETURN_URL=http://localhost:5173/payment-return